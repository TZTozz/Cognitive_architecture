<?xml version="1.0" ?>
<robot name="onrobot_2fg7">

  <!-- ======================== -->
  <!-- WORLD (fixed base)       -->
  <!-- ======================== -->
  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- ======================== -->
  <!-- BASE LINK                -->
  <!-- ======================== -->
  <link name="base_link">
    <inertial>
      <origin xyz="-4.898915958379213e-05 2.84756960271082e-06 0.06811082379774974" rpy="0 0 0"/>
      <mass value="1.2646523179240972"/>
      <inertia ixx="0.001504" iyy="0.001812" izz="0.001053" ixy="-0.0" iyz="0.0" ixz="-3e-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver">
        <color rgba="0.792156862745098 0.8196078431372549 0.9333333333333333 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ======================== -->
  <!-- LEFT FINGER              -->
  <!-- ======================== -->
  <link name="left_finger_link">
    <inertial>
      <origin xyz="0.004247703322119739 0.029496959480080673 0.015234215486237948" rpy="0 0 0"/>
      <mass value="0.023219383355922288"/>
      <inertia ixx="6e-06" iyy="5e-06" izz="2e-06" ixy="-0.0" iyz="0.0" ixz="-1e-06"/>
    </inertial>
    <visual>
      <origin xyz="-0.032239 0.029494 -0.12005" rpy="0 0 0"/>
      <geometry>
        <mesh filename="left_finger_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver">
        <color rgba="0.792156862745098 0.8196078431372549 0.9333333333333333 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.032239 0.029494 -0.12005" rpy="0 0 0"/>
      <geometry>
        <mesh filename="left_finger_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ======================== -->
  <!-- RIGHT FINGER             -->
  <!-- ======================== -->
  <link name="right_finger_link">
    <inertial>
      <origin xyz="0.017874296677847158 0.02949104051991925 0.01523421548622829" rpy="0 0 0"/>
      <mass value="0.023219383355922288"/>
      <inertia ixx="6e-06" iyy="5e-06" izz="2e-06" ixy="-0.0" iyz="-0.0" ixz="1e-06"/>
    </inertial>
    <visual>
      <origin xyz="0.054361 0.029494 -0.12005" rpy="0 0 0"/>
      <geometry>
        <mesh filename="right_finger_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver">
        <color rgba="0.792156862745098 0.8196078431372549 0.9333333333333333 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.054361 0.029494 -0.12005" rpy="0 0 0"/>
      <geometry>
        <mesh filename="right_finger_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- ======================== -->
  <!-- LEFT FINGER JOINT        -->
  <!-- Prismatic along -X       -->
  <!-- Stroke: 0 to 0.019m      -->
  <!-- ======================== -->
  <joint name="finger_joint" type="prismatic">
    <origin xyz="0.032239 -0.029494 0.12005" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_finger_link"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit lower="0.0" upper="0.019" effort="140" velocity="0.45"/>
    <dynamics damping="50.0" friction="1.0"/>
  </joint>

  <!-- ======================== -->
  <!-- RIGHT FINGER JOINT       -->
  <!-- Prismatic along +X       -->
  <!-- Mimic of finger_joint    -->
  <!-- ======================== -->
  <joint name="right_finger_joint" type="prismatic">
    <origin xyz="-0.054361 -0.029494 0.12005" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_finger_link"/>
    <axis xyz="1.0 0.0 0.0"/>
    <limit lower="-0.019" upper="0.019" effort="140" velocity="0.45"/>
    <dynamics damping="50.0" friction="1.0"/>
  </joint>

</robot>
